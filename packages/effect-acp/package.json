{
  "name": "effect-acp",
  "private": true,
  "type": "module",
  "exports": {
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "import": "./src/errors.ts"
    }
  },
  "scripts": {
    "dev": "tsdown src/schema.ts src/errors.ts --format esm,cjs --dts --watch --clean",
    "build": "tsdown src/schema.ts src/errors.ts --format esm,cjs --dts --clean",
    "prepare": "effect-language-service patch",
    "typecheck": "tsc --noEmit",
    "generate": "bun run scripts/generate.ts"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/openapi-generator": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
